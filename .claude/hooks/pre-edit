#!/bin/bash
#
# Claude Code Pre-Edit Hook
# Checks if repo is locked before allowing file edits
#
# This hook is called before Claude edits any file.
# If it exits with non-zero, the edit is blocked.
#

# Configuration
ORCHESTRATION_ROOT="/Users/marcin/Documents/VIMSS/ontology/KG-Hub/KG-Microbe/kg-microbe-orchestration"
REPO_NAME="mediaingredientmech"  # Will be replaced during installation

# Check lock
python3 "$ORCHESTRATION_ROOT/scripts/check_lock.py" "$REPO_NAME" "edit files"
EXIT_CODE=$?

if [ $EXIT_CODE -eq 0 ]; then
    # No lock, proceed
    exit 0
elif [ $EXIT_CODE -eq 1 ]; then
    # Locked, block
    echo ""
    echo "✋ Edit blocked by lock system"
    echo ""
    exit 1
else
    # Error
    echo "⚠️  Lock check failed, allowing edit (fail-open)"
    exit 0
fi
