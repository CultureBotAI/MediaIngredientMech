#!/bin/bash
#
# Claude Code Post-Edit Hook
# Updates status file after successful edit
#
# This hook is called after Claude successfully edits a file.
#

# Configuration
ORCHESTRATION_ROOT="/Users/marcin/Documents/VIMSS/ontology/KG-Hub/KG-Microbe/kg-microbe-orchestration"
REPO_NAME="mediaingredientmech"  # Will be replaced during installation
STATUS_DIR="$ORCHESTRATION_ROOT/status"
CLAUDE_ID="${REPO_NAME}_claude"

# Update status to indicate activity
cat > "$STATUS_DIR/${CLAUDE_ID}_status.yaml" <<EOF
last_updated: '$(date -u +%Y-%m-%dT%H:%M:%SZ)'
status: busy
current_operation: file_edit
last_completed_operation: null
next_available_at: '$(date -u +%Y-%m-%dT%H:%M:%SZ)'
EOF

# Always succeed (don't block edit)
exit 0
